// edit-distance.dot — a query-specific Levenshtein edit-distance transducer for
// the query "helo" with max distance k = 1, as built by
// EditDistanceTransducer::build_for_query. States are (position, error_count);
// the bold green path is the best (Viterbi) alignment "helo → hello" (one
// insertion, total cost 1.0). Arc labels read  in:out/weight  with ε = epsilon.
//
// SHARED DOT PREAMBLE (copy into every Graphviz automaton; palette = docs/diagrams/README.md):
//   bg #FFFFFF · node fill #BBDEFB / border #1565C0 · text #102027 · edge #607D8B
//   best/Viterbi #2E7D32 bold(penwidth=2) · alternative #B0BEC5 · epsilon #9E9E9E dashed
//   final = doublecircle fill #C8E6C9 border #2E7D32 · start = arrow from invisible point
digraph edit_distance {
  rankdir=LR;
  bgcolor="#FFFFFF";
  labelloc="t";
  fontname="Helvetica"; fontsize=13;
  label=<<b>Levenshtein transducer</b> for query "helo", k=1 &nbsp; — &nbsp; green = best alignment "helo → hello" (1 insertion)>;
  node  [shape=circle, style=filled, fillcolor="#BBDEFB", color="#1565C0",
         fontcolor="#102027", fontname="Helvetica", penwidth=1.4, width=0.55];
  edge  [color="#607D8B", fontcolor="#37474F", fontname="Helvetica", fontsize=10, penwidth=1.3];

  // start marker
  __start__ [shape=point, width=0.01, color="#1565C0"];
  __start__ -> p0e0;

  // (position, error) states.  Top row e=0 (no edits), bottom row e=1 (one edit).
  // position 0..=4 (chars of "helo" consumed), final at position 4 (any error).
  p0e0 [label="0,0"];
  p1e0 [label="1,0"];
  p2e0 [label="2,0"];
  p3e0 [label="3,0"];
  p4e0 [label="4,0", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];  // final
  p0e1 [label="0,1"];
  p1e1 [label="1,1"];
  p2e1 [label="2,1"];
  p3e1 [label="3,1"];
  p4e1 [label="4,1", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];  // final

  { rank=same; p0e0; p1e0; p2e0; p3e0; p4e0; }
  { rank=same; p0e1; p1e1; p2e1; p3e1; p4e1; }

  // ── e=0 row: exact matches of the query characters, cost 1̄ = 0.0 ──
  p0e0 -> p1e0 [label="h:h/0"];
  p1e0 -> p2e0 [label="e:e/0"];
  p2e0 -> p3e0 [label="l:l/0"];
  p3e0 -> p4e0 [label="o:o/0"];

  // ── e=1 row: matches after one edit has been spent ──
  p1e1 -> p2e1 [label="e:e/0"];
  p2e1 -> p3e1 [label="l:l/0"];
  // best path continuation: match the trailing 'o' after the inserted 'l'
  p3e1 -> p4e1 [label="o:o/0", color="#2E7D32", fontcolor="#1B5E20", penwidth=2.0];

  // ── error transitions (e=0 → e=1), each cost 1.0 ──
  // Insertion: consume ε, produce a character.  The best path inserts 'l'
  // between "hel" and "o" to reconstruct "hello".
  p3e0 -> p3e1 [label="ε:l/1", color="#2E7D32", fontcolor="#1B5E20", penwidth=2.0];
  // Representative alternatives (grey): deletion and substitution.
  p0e0 -> p1e1 [label="h:ε/1  (del)", color="#B0BEC5", fontcolor="#90A4AE"];
  p1e0 -> p2e1 [label="e:a/1  (sub)", color="#B0BEC5", fontcolor="#90A4AE"];
  // Insertion from the start (alternative).
  p0e0 -> p0e1 [label="ε:x/1  (ins)", color="#9E9E9E", style=dashed];
}

// code-switch.dot — a code-switching lattice over the bilingual phrase
// "hello mundo" produced by CodeSwitchTransducer. One state per language (en, es);
// language-tagged word arcs are self-loops, cross-language arcs carry the switch
// penalty. The bold green path "hello"(en) → switch → "mundo"(es) is the best
// (Viterbi) assignment found by best_path. Arc labels read  word [lang] / cost.
//
// SHARED DOT PREAMBLE (copy into every Graphviz automaton; palette = docs/diagrams/README.md):
//   bg #FFFFFF · node fill #BBDEFB / border #1565C0 · text #102027 · edge #607D8B
//   best/Viterbi #2E7D32 bold(penwidth=2) · alternative #B0BEC5 · epsilon #9E9E9E dashed
//   final = doublecircle fill #C8E6C9 border #2E7D32 · start = arrow from invisible point
digraph code_switch {
  rankdir=LR;
  bgcolor="#FFFFFF";
  labelloc="t";
  fontname="Helvetica"; fontsize=13;
  label=<<b>Code-switching lattice</b> for "hello mundo" &nbsp; — &nbsp; green = best path (en → switch → es); amber = language-tagged arcs>;
  node  [shape=circle, style=filled, fillcolor="#BBDEFB", color="#1565C0",
         fontcolor="#102027", fontname="Helvetica", penwidth=1.4, width=0.7];
  edge  [color="#607D8B", fontcolor="#37474F", fontname="Helvetica", fontsize=10, penwidth=1.3];

  // super-start with ε-arcs into each language (allow_any_start = true)
  __start__ [shape=point, width=0.01, color="#1565C0"];
  S [label="S", fillcolor="#ECEFF1", color="#455A64"];
  __start__ -> S;

  // language states (final: any language may end the utterance)
  EN [label="en", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];
  ES [label="es", shape=doublecircle, fillcolor="#FFF59D", color="#F9A825"];

  // ε entry into both languages
  S -> EN [label="ε", color="#9E9E9E", style=dashed];
  S -> ES [label="ε", color="#9E9E9E", style=dashed];

  // ── en self-loops (in-language words, low cost) ──
  EN -> EN [label="hello [en] / 0.5", color="#F9A825", fontcolor="#E65100"];
  EN -> EN [label="world [en] / 0.5", color="#F9A825", fontcolor="#E65100"];

  // ── es self-loops (in-language words, low cost) ──
  ES -> ES [label="mundo [es] / 0.5", color="#F9A825", fontcolor="#E65100"];
  ES -> ES [label="hola  [es] / 0.5", color="#F9A825", fontcolor="#E65100"];

  // ── cross-language arcs carry the switch penalty (switch_penalty = 1.0) ──
  // best path: read "hello" in en (self-loop), then switch en→es to read "mundo".
  EN -> ES [label="mundo [es] / +switch", color="#2E7D32", fontcolor="#1B5E20", penwidth=2.0];
  ES -> EN [label="word  [en] / +switch", color="#B0BEC5", fontcolor="#90A4AE"];

  // mark the in-language leg of the best path green as well
  EN -> EN [label="hello [en] / 0.5  ★", color="#2E7D32", fontcolor="#1B5E20", penwidth=2.0];
}

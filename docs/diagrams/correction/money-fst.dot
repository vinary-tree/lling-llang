// money-fst.dot — a MONEY-class verbalizer WFST realizing the TN mapping
// "$5" → "five dollars" (semiotic class MONEY, τ_MONEY). The integer part is
// verbalized as a CARDINAL, then the currency name is appended. The bold green
// path is the single accepting derivation. Arc labels read  in:out/weight, where
// ε denotes the empty label (consume/emit nothing).
//
// SHARED DOT PREAMBLE (copy into every Graphviz automaton; palette = docs/diagrams/README.md):
//   bg #FFFFFF · node fill #BBDEFB / border #1565C0 · text #102027 · edge #607D8B
//   best/Viterbi #2E7D32 bold(penwidth=2) · alternative #B0BEC5 · epsilon #9E9E9E dashed
//   final = doublecircle fill #C8E6C9 border #2E7D32 · start = arrow from invisible point
digraph money_fst {
  rankdir=LR;
  bgcolor="#FFFFFF";
  labelloc="t";
  fontname="Helvetica"; fontsize=13;
  label=<<b>MONEY verbalizer</b> &nbsp; τ<sub>MONEY</sub> : &nbsp; "$5" → "five dollars">;
  node  [shape=circle, style=filled, fillcolor="#BBDEFB", color="#1565C0",
         fontcolor="#102027", fontname="Helvetica", penwidth=1.4, width=0.55];
  edge  [color="#607D8B", fontcolor="#37474F", fontname="Helvetica", fontsize=11, penwidth=1.3];

  __start__ [shape=point, width=0.01, color="#1565C0"];
  __start__ -> q0;

  q0 [label="0"];
  q1 [label="1"];
  q2 [label="2"];
  q3 [label="3", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];  // final

  // Best (only) accepting derivation — bold green.
  // 1) consume the currency symbol '$', emit nothing (ε): it is realized later as a word.
  q0 -> q1 [label="$:ε / 0.0", color="#2E7D32", fontcolor="#1B5E20", penwidth=2.0];
  // 2) verbalize the integer amount 5 as a CARDINAL → "five".
  q1 -> q2 [label="5:five / 0.0", color="#2E7D32", fontcolor="#1B5E20", penwidth=2.0];
  // 3) emit the (plural) currency name from MoneyConfig.name_plural.
  q2 -> q3 [label="ε:dollars / 0.0", color="#2E7D32", fontcolor="#1B5E20", penwidth=2.0];

  // Alternative: a singular amount selects the singular currency name ("$1 → one dollar").
  q2 -> q3 [label="ε:dollar / 1.0  (if amount = 1)", color="#B0BEC5", fontcolor="#90A4AE"];
}

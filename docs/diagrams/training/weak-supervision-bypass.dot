// weak-supervision-bypass.dot — WST training graph with bypass arcs over a noisy
// transcript "the cat sat". The token "cat" has low confidence (0.30) so a token
// bypass ε-arc lets the aligner skip it; a multi-token bypass spans two states;
// blank self-loops absorb timing slack. Matches build_wst_graph / WstConfig in
// src/training/weak_supervision.rs.
//
// SHARED DOT PREAMBLE (palette = docs/diagrams/README.md):
//   bg #FFFFFF · node fill #BBDEFB / border #1565C0 · text #102027 · edge #607D8B
//   best/Viterbi #2E7D32 bold(penwidth=2) · alternative #B0BEC5 · epsilon #9E9E9E dashed
//   final = doublecircle fill #C8E6C9 border #2E7D32 · start = arrow from invisible point
digraph weak_supervision_bypass {
  rankdir=LR;
  bgcolor="#FFFFFF";
  labelloc="t";
  fontname="Helvetica"; fontsize=13;
  label=<<b>WST training graph</b> — solid = token arcs; dashed grey = ε bypass / blank arcs for noisy "cat">;
  node  [shape=circle, style=filled, fillcolor="#BBDEFB", color="#1565C0",
         fontcolor="#102027", fontname="Helvetica", penwidth=1.4, width=0.5];
  edge  [color="#607D8B", fontcolor="#37474F", fontname="Helvetica", fontsize=11, penwidth=1.3];

  __start__ [shape=point, width=0.01, color="#1565C0"];
  __start__ -> q0;

  q0 [label="0"];
  q1 [label="1"];
  q2 [label="2"];
  q3 [label="3", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];

  // token arcs (confident tokens stay on the bold-green main path)
  q0 -> q1 [label="the / conf 0.95", color="#2E7D32", fontcolor="#1B5E20", penwidth=2.0];
  q1 -> q2 [label="cat / conf 0.30"];
  q2 -> q3 [label="sat / conf 0.90", color="#2E7D32", fontcolor="#1B5E20", penwidth=2.0];

  // single-token bypass over the low-confidence "cat": weight = w·(1−conf)
  q1 -> q2 [label="ε  (bypass cat, 2.0·0.7 = 1.4)", color="#9E9E9E", style=dashed];

  // multi-token bypass span (max_bypass_span ≥ 2): skip "cat sat" in one hop
  q1 -> q3 [label="ε  (multi-bypass span, cost ↑)", color="#9E9E9E", style=dashed, constraint=false];

  // blank self-loops: absorb extra blank frames for timing flexibility
  q0 -> q0 [label="␣  blank / β=0.5", color="#9E9E9E", style=dashed];
  q1 -> q1 [label="␣  blank / β=0.5", color="#9E9E9E", style=dashed];
  q2 -> q2 [label="␣  blank / β=0.5", color="#9E9E9E", style=dashed];
}

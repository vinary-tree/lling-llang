// wfst-operations.dot — the three rational constructions on WFSTs as ε-wired
// automaton sketches: union (T₁ ⊕ T₂), concatenation (T₁ ⊗ T₂), and closure (T*).
// Grey dashed = the ε-arcs each construction adds; green double ring = final states.
//
// SHARED DOT PREAMBLE (palette = docs/diagrams/README.md):
//   bg #FFFFFF · node fill #BBDEFB / border #1565C0 · text #102027 · edge #607D8B
//   best/Viterbi #2E7D32 bold(penwidth=2) · alternative #B0BEC5 · epsilon #9E9E9E dashed
//   final = doublecircle fill #C8E6C9 border #2E7D32 · start = arrow from invisible point
digraph wfst_operations {
  rankdir=LR;
  bgcolor="#FFFFFF";
  fontname="Helvetica"; fontsize=13;
  compound=true;
  labelloc="t";
  label=<<b>Rational constructions</b> — grey dashed arcs are the ε-transitions each operation adds>;
  node  [shape=circle, style=filled, fillcolor="#BBDEFB", color="#1565C0",
         fontcolor="#102027", fontname="Helvetica", penwidth=1.4, width=0.45];
  edge  [color="#607D8B", fontcolor="#37474F", fontname="Helvetica", fontsize=11, penwidth=1.3];

  // ───────────────────────── Union: T₁ ⊕ T₂ ─────────────────────────
  subgraph cluster_union {
    label=<<b>Union</b>  T₁ ⊕ T₂>;
    labeljust="l"; color="#1565C0"; fontcolor="#102027"; style="rounded"; bgcolor="#F5F9FF";
    u_start [label="s", fillcolor="#BBDEFB", color="#1565C0"];
    u_a0 [label="T₁"]; u_a1 [label="", width=0.18, fixedsize=true];
    u_b0 [label="T₂"]; u_b1 [label="", width=0.18, fixedsize=true];
    u_f  [label="f", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];

    u_start -> u_a0 [label="ε", color="#9E9E9E", style=dashed, fontcolor="#616161"];
    u_start -> u_b0 [label="ε", color="#9E9E9E", style=dashed, fontcolor="#616161"];
    u_a0 -> u_a1 [color="#B0BEC5"];
    u_b0 -> u_b1 [color="#B0BEC5"];
    u_a1 -> u_f [label="ε", color="#9E9E9E", style=dashed, fontcolor="#616161"];
    u_b1 -> u_f [label="ε", color="#9E9E9E", style=dashed, fontcolor="#616161"];
  }

  // ───────────────────────── Concatenation: T₁ ⊗ T₂ ──────────────────
  subgraph cluster_concat {
    label=<<b>Concatenation</b>  T₁ ⊗ T₂>;
    labeljust="l"; color="#2E7D32"; fontcolor="#102027"; style="rounded"; bgcolor="#F4FBF4";
    c_start [label="s", fillcolor="#BBDEFB", color="#1565C0"];
    c_a0 [label="T₁"]; c_a1 [label="", width=0.18, fixedsize=true];
    c_b0 [label="T₂"]; c_f  [label="f", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];

    c_start -> c_a0 [color="#B0BEC5"];
    c_a0 -> c_a1 [color="#B0BEC5"];
    c_a1 -> c_b0 [label="ε / ρ(T₁)", color="#9E9E9E", style=dashed, fontcolor="#616161"];
    c_b0 -> c_f [color="#B0BEC5"];
  }

  // ───────────────────────── Closure: T* ─────────────────────────────
  subgraph cluster_closure {
    label=<<b>Closure</b>  T*>;
    labeljust="l"; color="#00695C"; fontcolor="#102027"; style="rounded"; bgcolor="#F2FAF9";
    // super-start is itself final (accepts ε)
    k_start [label="s", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];
    k_t0 [label="T"]; k_t1 [label="", width=0.18, fixedsize=true];

    k_start -> k_t0 [label="ε", color="#9E9E9E", style=dashed, fontcolor="#616161"];
    k_t0 -> k_t1 [color="#B0BEC5"];
    k_t1 -> k_start [label="ε (loop)", color="#9E9E9E", style=dashed, fontcolor="#616161", constraint=false];
  }
}

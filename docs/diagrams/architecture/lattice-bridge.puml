@startuml lattice-bridge
' The semiring ↔ lattice bridge (feature = "lattice").
' Top: the blanket-impl relationship. Any S : Semiring + IdempotentSemiring is a
'   SemiringLattice (blanket impl); SemiringLatticeWrapper<S> then implements
'   llattice::Lattice (join = ⊕, meet = ⊗) and libdictenstein::DictionaryValue.
' Bottom: an object snapshot showing two dictionary values for the SAME key being
'   union-merged via join = semiring ⊕ (Tropical: min).
' Palette: docs/diagrams/README.md (Foundation = blue #BBDEFB / #1565C0;
'   Correction/value = amber #FFF59D / #F9A825; Algorithms/result = green #C8E6C9 / #2E7D32;
'   Neutral = #ECEFF1 / #455A64).
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultTextAlignment left
skinparam ArrowColor #607D8B
skinparam class {
  BackgroundColor #BBDEFB
  BorderColor #1565C0
  FontColor #102027
}
skinparam object {
  BackgroundColor #FFF59D
  BorderColor #F9A825
  FontColor #102027
}
hide empty members

title <b>Semiring ↔ lattice bridge</b>  (feature = "lattice")\n<size:11><i>blanket impl: any idempotent semiring becomes a libdictenstein dictionary value whose union-merge join = ⊕</i></size>

interface "Semiring\n(K, ⊕, ⊗, 0̄, 1̄)" as S {
  +plus(&Self) : Self    .. ⊕
  +times(&Self) : Self   .. ⊗
}
interface "IdempotentSemiring" as IDEM #FFF59D {
  .. marker: a ⊕ a = a ..
}
interface "SemiringLattice" as SL #C8E6C9 {
  .. blanket marker ..
}
interface "llattice::Lattice" as LAT #BBDEFB {
  +join(&Self) : Self    .. ⊕
  +meet(&Self) : Self    .. ⊗
}
interface "libdictenstein::\nDictionaryValue" as DV #ECEFF1 {
  .. Clone+Default+Send+Sync+'static ..
}
class "SemiringLatticeWrapper<S>" as W #FFF59D {
  +0 : S
  --
  join = ⊕  (union-merge)
  meet = ⊗  (path compose)
}

S <|-- IDEM
IDEM <|-- SL : "blanket impl\nfor all S : Semiring + IdempotentSemiring"
W ..|> LAT  : join = self.0.plus(&other.0)\nmeet = self.0.times(&other.0)
W ..|> DV   : (serde-bounded if\nfeature lattice-persistent)
SL .right.> W : wraps S

note bottom of LAT
  Idempotent ⊕ satisfies the join-semilattice laws
  (idempotent, commutative, associative), so ⊕ is a
  lawful <b>join</b>. ⊗ is path composition, not a true
  meet — supply a real meet for other semirings.
end note

' ── object snapshot: union-merge of two values for the SAME dictionary key ──
object "left : Wrapper<Tropical>" as L #FFF59D {
  0 = Tropical(10.0)
}
object "right : Wrapper<Tropical>" as R #FFF59D {
  0 = Tropical(5.0)
}
object "merged : Wrapper<Tropical>" as M #C8E6C9 {
  0 = Tropical(5.0)
  = left.join(right)
  = ⊕ = min(10, 5)
}
L -[#2E7D32,bold]-> M : join (⊕)
R -[#2E7D32,bold]-> M : join (⊕)
@enduml

@startuml lattice
' Worked-example correction lattice as a left-to-right WFSA.
' Green arcs = the best (Viterbi) path: the / quick / fox = 1.0.
left to right direction
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultTextAlignment center
skinparam state {
  BackgroundColor #BBDEFB
  BorderColor #1565C0
  FontColor #102027
  FontStyle bold
}
skinparam ArrowColor #607D8B
skinparam ArrowThickness 1.3
hide empty description

title <b>Correction lattice</b>  —  green marks the best (Viterbi) path

[*] --> s0
state "0" as s0
state "1" as s1
state "2" as s2
state "3" as s3 #C8E6C9

s0 -[#2E7D32,bold]-> s1 : the / 0.5
s0 -[#B0BEC5]->      s1 : teh / 1.0
s1 -[#2E7D32,bold]-> s2 : quick / 0.5
s1 -[#B0BEC5]->      s2 : quik / 1.0
s2 -[#2E7D32,bold]-> s3 : fox / 0.0
s3 --> [*]
@enduml

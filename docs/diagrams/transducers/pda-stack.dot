// pda-stack.dot — a weighted pushdown automaton recognizing { aⁿbⁿ ∣ n ≥ 1 }.
// Mirrors PdaBuilder::a_n_b_n: q₀ reads a's (pushing markers γ), an ε-move switches
// to q₁ which pops a γ per b, and an ε-move on Z₀ accepts in q₂.
// Arc labels read  input , stack_top → stack_action.   ε-moves drawn grey/dashed.
//
// SHARED DOT PREAMBLE (palette = docs/diagrams/README.md):
//   bg #FFFFFF · node fill #BBDEFB / border #1565C0 · text #102027 · edge #607D8B
//   transducer-family accent fill #B2DFDB / border #00695C
//   final = doublecircle fill #C8E6C9 border #2E7D32 · start = arrow from invisible point
//   epsilon: #9E9E9E dashed
digraph pda_anbn {
  rankdir=LR;
  bgcolor="#FFFFFF";
  labelloc="t";
  fontname="Helvetica"; fontsize=13;
  label=<<b>PDA for aⁿbⁿ</b> — arc = <i>input , top → action</i>; Z₀ = bottom marker, γ = a-marker>;
  node  [shape=circle, style=filled, fillcolor="#B2DFDB", color="#00695C",
         fontcolor="#102027", fontname="Helvetica", penwidth=1.4, width=0.62];
  edge  [color="#607D8B", fontcolor="#37474F", fontname="Helvetica", fontsize=11, penwidth=1.3];

  __start__ [shape=point, width=0.01, color="#1565C0"];
  __start__ -> q0;

  q0 [label="q₀\nread a"];
  q1 [label="q₁\nread b"];
  q2 [label="q₂\naccept", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];

  // push markers while reading a's (two arcs: first 'a' on Z₀, more 'a's on γ)
  q0 -> q0 [label="a , Z₀ → push[Z₀,γ]"];
  q0 -> q0 [label="a , γ → push[γ,γ]"];

  // ε-switch to the b-reading phase when a γ is exposed
  q0 -> q1 [label="ε , γ → noop", color="#9E9E9E", style=dashed, fontcolor="#37474F"];

  // pop one marker per b
  q1 -> q1 [label="b , γ → pop"];

  // ε-accept once only Z₀ remains
  q1 -> q2 [label="ε , Z₀ → noop", color="#9E9E9E", style=dashed, fontcolor="#37474F"];
}

@startuml pda-trace
' Instantaneous-description (ID) trace of the aⁿbⁿ PDA on input "aabb".
' Each node is an ID (q, w, γ): state · remaining input · stack (top at right).
' The ⊢ relation steps one transition; ε-moves are amber, accept node is green.
' Palette: docs/diagrams/README.md (transducer family teal; final green).
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultTextAlignment center
skinparam state {
  BackgroundColor #B2DFDB
  BorderColor #00695C
  FontColor #102027
  FontStyle bold
}
skinparam ArrowColor #607D8B
skinparam ArrowThickness 1.3
hide empty description

title <b>ID trace</b>  —  PDA on "aabb"; each node is (state, remaining input, stack)

[*] --> id0
state "id0\n(q₀, aabb, Z₀)" as id0
state "id1\n(q₀, abb, Z₀γ)" as id1
state "id2\n(q₀, bb, Z₀γγ)" as id2
state "id3\n(q₁, bb, Z₀γγ)" as id3
state "id4\n(q₁, b, Z₀γ)" as id4
state "id5\n(q₁, ε, Z₀)" as id5
state "id6\n(q₂, ε, Z₀)" as id6 #C8E6C9

id0 -[#00695C,bold]-> id1 : read a · push γ
id1 -[#00695C,bold]-> id2 : read a · push γ
id2 -[#F9A825,bold]-> id3 : ε · switch phase
id3 -[#00695C,bold]-> id4 : read b · pop γ
id4 -[#00695C,bold]-> id5 : read b · pop γ
id5 -[#F9A825,bold]-> id6 : ε · accept (Z₀, input ε)
id6 --> [*]
@enduml

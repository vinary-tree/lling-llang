// multitape-2tape.dot — a 2-tape weighted transducer over the alphabet pair
// (Σ₁ = surface, Σ₂ = lemma) reading the word "cats" → lemma "cat". Each arc
// carries a multi-tape label [a₁ : a₂] / weight, with ε on a tape drawn grey.
//
// SHARED DOT PREAMBLE (palette = docs/diagrams/README.md):
//   bg #FFFFFF · node fill #BBDEFB / border #1565C0 · text #102027 · edge #607D8B
//   best/Viterbi #2E7D32 bold(penwidth=2) · alternative #B0BEC5 · epsilon #9E9E9E dashed
//   final = doublecircle fill #C8E6C9 border #2E7D32 · start = arrow from invisible point
//   transducer-family accent fill #B2DFDB / border #00695C
digraph multitape_2tape {
  rankdir=LR;
  bgcolor="#FFFFFF";
  labelloc="t";
  fontname="Helvetica"; fontsize=13;
  label=<<b>2-tape transducer</b> — tape₁ (surface) : tape₂ (lemma); grey = ε on that tape>;
  node  [shape=circle, style=filled, fillcolor="#B2DFDB", color="#00695C",
         fontcolor="#102027", fontname="Helvetica", penwidth=1.4, width=0.5];
  edge  [color="#607D8B", fontcolor="#37474F", fontname="Helvetica", fontsize=11, penwidth=1.3];

  // start marker
  __start__ [shape=point, width=0.01, color="#1565C0"];
  __start__ -> q0;

  q0 [label="q₀"];
  q1 [label="q₁"];
  q2 [label="q₂"];
  q3 [label="q₃"];
  q4 [label="q₄", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];   // final ρ(q₄)=0̄? no: 1̄

  // the c, a, t letters are copied on both tapes (surface == lemma)
  q0 -> q1 [label="[c : c] / 0", color="#00695C", fontcolor="#004D40", penwidth=1.6];
  q1 -> q2 [label="[a : a] / 0", color="#00695C", fontcolor="#004D40", penwidth=1.6];
  q2 -> q3 [label="[t : t] / 0", color="#00695C", fontcolor="#004D40", penwidth=1.6];

  // the plural "s" is consumed on tape₁ but emits ε on tape₂ (lemma drops it)
  q3 -> q4 [label="[s : ε] / 0.5", color="#9E9E9E", style=dashed, fontcolor="#37474F"];
}

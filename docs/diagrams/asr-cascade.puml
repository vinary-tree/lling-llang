@startuml asr-cascade
' ASR recognition-network construction and decoding.
' Tildes (H̃, C̃, L̃) denote auxiliary-symbol-augmented transducers; π erases them.
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultTextAlignment center
skinparam rectangle {
  RoundCorner 12
  FontColor #102027
  BorderColor #E65100
}
skinparam ArrowColor #BF360C
skinparam ArrowThickness 1.4

title <b>ASR recognition cascade</b>\n<latex>N = \pi( \min( \det( H \circ \det( C \circ \det( L \circ G ) ) ) ) )</latex>   <size:10>(Mohri, Pereira & Riley 2002)</size>

rectangle "<b>H</b> — HMM transducer\nHMM states → context-dep. phones" as H #FFE0B2
rectangle "<b>C</b> — context dependency\ntriphones → phones" as C #FFE0B2
rectangle "<b>L</b> — pronunciation lexicon\nphone strings → words" as L #FFE0B2
rectangle "<b>G</b> — grammar / n-gram LM\nwords → words" as G #FFE0B2

H -right-> C : <latex>\circ</latex>
C -right-> L : <latex>\circ</latex>
L -right-> G : <latex>\circ</latex>

rectangle "<b>Optimize</b>\ndet (determinize) · min (minimize) · <latex>\pi</latex> (erase aux symbols)" as OPT #FFCC80
rectangle "<b>N</b> — static decoding graph\nHMM states → words" as N #FFB74D

G -down-> OPT
OPT -down-> N

rectangle "<b>Acoustic posteriors</b>\n<latex>P(\text{unit} \mid \text{frame})</latex>  from a neural acoustic model" as AM #E1BEE7
rectangle "<b>Search</b>\nViterbi / beam over  <latex>AM \circ N</latex>" as DEC #C8E6C9
rectangle "<b>Words</b>" as W #ECEFF1

N  -down-> DEC
AM -down-> DEC
DEC -down-> W

@enduml

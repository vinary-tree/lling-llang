@startuml formal-verification
' Machine-checked foundations: Coq/Rocq proofs (left) and TLA+ models (right).
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultTextAlignment center
skinparam rectangle {
  RoundCorner 12
  FontColor #102027
}
skinparam ArrowColor #B71C1C
skinparam ArrowThickness 1.4
hide stereotype

title <b>Formal verification</b>  —  Coq/Rocq proofs  ·  TLA⁺ models\n<size:11><i>no admits, axioms, or sorry — every proof file builds clean</i></size>

rectangle "<b>Coq / Rocq</b>" as COQ #FFEBEE {
  rectangle "<b>Foundations</b>\nsemiring laws · tropical & log\nquantization · interval · roundoff\nmatrix closure" as F1 #FFCDD2
  rectangle "<b>WFST semantics</b>\ndefinitions · paths\nmatrix semantics · weighted language L(A)" as F2 #EF9A9A
  rectangle "<b>Algorithm specs</b>\nviterbi · shortest-distance\ndeterminize · minimize\n(partial-correctness)" as F3 #E57373
  F1 -down-> F2
  F2 -down-> F3
}

rectangle "<b>TLA⁺ (TLC model checking)</b>" as TLA #FFEBEE {
  rectangle "RRWM\nbounded online-learning accounting" as T1 #FFCDD2
  rectangle "LazyComposition\ncache / memory bounds" as T2 #FFCDD2
  rectangle "CascadeOrder\nH → C → L → G ordering" as T3 #FFCDD2
}

note bottom of TLA
  9 TLC configurations
  + 3 expected-failure mutants
end note

COQ -[hidden]- TLA

@enduml

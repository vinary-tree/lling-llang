// gpu-token-recombination.dot — lock-free token recombination via uint64 atomic-min
// (src/gpu/token_recombine.rs). Competing tokens at a destination state are packed as
// [cost: high 32 bits | arc_id: low 32 bits]; an order-preserving float→uint transform
// makes integer atomicMin select the lowest cost with NO precision loss.
//   ordered = (cost_bits ≥ 0) ? cost_bits ⊕ 0x80000000 : ¬cost_bits
// Purple = deep-learning/GPU tier (palette = docs/diagrams/README.md).
digraph gpu_token_recombination {
  rankdir=LR;
  bgcolor="#FFFFFF";
  labelloc="t";
  fontname="Helvetica"; fontsize=13;
  label=<<b>uint64 token recombination</b> — pack (cost, arc_id), order-preserving bits, atomicMin per state>;
  node  [shape=box, style="filled,rounded", fillcolor="#E1BEE7", color="#6A1B9A",
         fontcolor="#102027", fontname="Helvetica", penwidth=1.4];
  edge  [color="#6A1B9A", fontcolor="#37474F", fontname="Helvetica", fontsize=10, penwidth=1.3];

  // ── Incoming candidate tokens for destination state q ─────────────────────────
  subgraph cluster_tokens {
    label=<candidate tokens → state q>; color="#9E9E9E"; fontcolor="#455A64"; style=dashed;
    t1 [label="token A\ncost 0.5 · arc 7"];
    t2 [label="token B\ncost 1.2 · arc 3"];
    t3 [label="token C\ncost 0.3 · arc 9"];
  }

  // ── Pack stage: 64-bit record, cost in HIGH bits so atomicMin compares cost first
  pack [shape=record, fillcolor="#D1C4E9",
        label="{ pack_cost_arc | {<hi> cost (f32)\nhigh 32 bits | <lo> arc_id (u32)\nlow 32 bits} }"];

  // ── Order-preserving float transform (so integer compare == float compare) ────
  order [label="float→uint order\n(cost⊕0x80000000 if ≥0,\nelse ¬cost_bits)", fillcolor="#F3E5F5"];

  // ── Atomic min on the per-state packed slot ───────────────────────────────────
  amin [label="atomicMin\nstate_to_token[q]", fillcolor="#CE93D8", color="#4A148C"];

  // ── Winner: lowest-cost token survives (green = best/Viterbi accent) ──────────
  win [label="survivor: token C\ncost 0.3 · arc 9", fillcolor="#C8E6C9", color="#2E7D32"];

  t1 -> pack; t2 -> pack; t3 -> pack;
  pack -> order [label="64-bit word"];
  order -> amin [label="ordered u64"];
  amin -> win   [label="min wins", color="#2E7D32", penwidth=2.0];

  // per-arc buffer note (no write conflicts)
  buf [shape=note, fillcolor="#FFF59D", color="#F9A825", label="per-arc buffer[arc_id]\n← full token (no contention)"];
  amin -> buf [style=dashed, label="on win"];
}

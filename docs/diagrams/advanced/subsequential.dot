// subsequential.dot — a deterministic subsequential transducer with residual (final)
// outputs (src/subsequential/). Input-deterministic: at most one outgoing arc per input
// symbol at each state. Each final state carries a residual string appended on accept
// (here state 2 emits "!"). Matches the uppercase-style example in the doc:
//   apply("ab") = "A"·"B"·residual("!") = "AB!".
// Transducer-family tier = teal (palette = docs/diagrams/README.md).
digraph subsequential {
  rankdir=LR;
  bgcolor="#FFFFFF";
  labelloc="t";
  fontname="Helvetica"; fontsize=13;
  label=<<b>Subsequential transducer</b> — input-deterministic; final states carry a residual output (state 2 ⇒ "!")>;
  node  [shape=circle, style=filled, fillcolor="#B2DFDB", color="#00695C",
         fontcolor="#102027", fontname="Helvetica", penwidth=1.4, width=0.55];
  edge  [color="#00796B", fontcolor="#37474F", fontname="Helvetica", fontsize=11, penwidth=1.3];

  __start__ [shape=point, width=0.01, color="#00695C"];
  __start__ -> s0;

  s0 [label="s0"];
  s1 [label="s1"];
  // final state: double ring + residual output shown beneath the id
  s2 [label="s2\n/ \"!\"", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];

  // exactly one transition per input symbol at each state (deterministic)
  s0 -> s1 [label="a : A"];
  s1 -> s2 [label="b : B"];

  // residual emission on acceptance (dashed teal → terminal accept)
  __accept__ [shape=point, width=0.01, color="#2E7D32"];
  s2 -> __accept__ [label="ε / residual \"!\"", color="#2E7D32", style=dashed, fontcolor="#1B5E20"];
}

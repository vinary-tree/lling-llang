// fsm-mask.dot — a compressed-FSM fragment for a tiny JSON-ish grammar and the
// token mask each state induces over a 6-token vocabulary. Green = the path the
// decoder is following; the mask table shows m[v]=1 (●) / 0 (·) per state.
// The brace tokens are written LBRACE / RBRACE in the table to avoid record
// delimiter escaping; the FSM arcs use the literal glyphs.
//
// SHARED DOT PREAMBLE (palette = docs/diagrams/README.md):
//   bg #FFFFFF · state fill #BBDEFB / border #1565C0 · best path #2E7D32 bold
//   final = doublecircle fill #C8E6C9 border #2E7D32 · mask table = HTML, amber tier
digraph fsm_mask {
  rankdir=LR;
  bgcolor="#FFFFFF";
  labelloc="t";
  fontname="Helvetica"; fontsize=13;
  label=<<b>Compressed FSM masking a vocabulary</b> — m[v] = 1 iff an arc out of q reads v>;
  node  [shape=circle, style=filled, fillcolor="#BBDEFB", color="#1565C0",
         fontcolor="#102027", fontname="Helvetica", penwidth=1.4, width=0.5];
  edge  [color="#607D8B", fontcolor="#37474F", fontname="Helvetica", fontsize=11, penwidth=1.3];

  __start__ [shape=point, width=0.01, color="#1565C0"];
  __start__ -> q0;

  q0 [label="q0"];
  q1 [label="q1"];
  q2 [label="q2"];
  q3 [label="q3", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];

  // accepting path  {  "k"  :  }   (green / bold)
  q0 -> q1 [label="'{'",  color="#2E7D32", fontcolor="#1B5E20", penwidth=2.0];
  q1 -> q2 [label="\"k\"", color="#2E7D32", fontcolor="#1B5E20", penwidth=2.0];
  q2 -> q3 [label="':'",  color="#2E7D32", fontcolor="#1B5E20", penwidth=2.0];
  // a competing (allowed but not taken) continuation from q1
  q1 -> q1 [label="ws", color="#B0BEC5"];

  // token-mask table (HTML-like): vocabulary V = { LBRACE, "k", :, RBRACE, ws, 123 }
  mask [shape=plaintext, label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="4"
           color="#F9A825" bgcolor="#FFF59D">
      <tr><td><b>state</b></td><td>LBRACE</td><td>"k"</td><td>:</td><td>RBRACE</td><td>ws</td><td>123</td></tr>
      <tr><td>q0</td><td>●</td><td>·</td><td>·</td><td>·</td><td>·</td><td>·</td></tr>
      <tr><td>q1</td><td>·</td><td>●</td><td>·</td><td>·</td><td>●</td><td>·</td></tr>
      <tr><td>q2</td><td>·</td><td>·</td><td>●</td><td>·</td><td>·</td><td>·</td></tr>
      <tr><td>q3 (final)</td><td>·</td><td>·</td><td>·</td><td>·</td><td>·</td><td>·</td></tr>
    </table>>];

  // dotted advisories linking each state to its mask row
  edge [color="#9E9E9E", style=dotted, arrowhead=none, constraint=false];
  q0 -> mask;
  q1 -> mask;
  q2 -> mask;
  q3 -> mask;
}

// ctc-compact.dot ‚Äî Compact-CTC topology (N=3). Instead of the N¬≤ all-to-all arcs,
// each non-blank label backs off THROUGH the blank state. Arc budget = 3N‚àí2:
//   ‚Ä¢ N self-loops (one per state, incl. blank)            = N
//   ‚Ä¢ N‚àí1 blank‚Üílabel entry arcs (Œµ:label)                 = N‚àí1
//   ‚Ä¢ N‚àí1 label‚Üíblank back-off arcs (label:Œµ)              = N‚àí1
//   ‚áí N + 2(N‚àí1) = 3N‚àí2.  For N=3 ‚Üí 7 arcs.
// Blank (state 0) is start and final.  `dot` left-to-right layout.
//
// SHARED DOT PREAMBLE (palette = docs/diagrams/README.md):
//   bg #FFFFFF ¬∑ node fill #BBDEFB / border #1565C0 ¬∑ text #102027 ¬∑ edge #607D8B
//   best/Viterbi #2E7D32 bold(penwidth=2) ¬∑ alternative #B0BEC5 ¬∑ epsilon #9E9E9E dashed
//   final = doublecircle fill #C8E6C9 border #2E7D32 ¬∑ start = arrow from invisible point
digraph ctc_compact {
  rankdir=LR;
  bgcolor="#FFFFFF";
  labelloc="t";
  fontname="Helvetica"; fontsize=13;
  label=<<b>Compact-CTC (N=3)</b> ‚Äî back-off through blank: 3N‚àí2 arcs (7 for N=3)>;
  node  [shape=circle, style=filled, fillcolor="#BBDEFB", color="#1565C0",
         fontcolor="#102027", fontname="Helvetica", penwidth=1.4, width=0.6];
  edge  [color="#607D8B", fontcolor="#37474F", fontname="Helvetica", fontsize=11, penwidth=1.3];

  __start__ [shape=point, width=0.01, color="#1565C0"];
  __start__ -> b;

  b [label="blank\n0", shape=doublecircle, fillcolor="#FFE0B2", color="#E65100"];
  a [label="a\n1"];
  c [label="b\n2"];

  // self-loops (1 per state) ‚Äî blank's is the Œµ self-loop
  b -> b [label="Œµ / -", color="#9E9E9E", style=dashed];
  a -> a [label="a:Œµ (self)"];
  c -> c [label="b:Œµ (self)"];

  // blank ‚Üí label entry arcs (Œµ:label) ‚Äî N‚àí1 of them
  b -> a [label="Œµ:a"];
  b -> c [label="Œµ:b"];

  // label ‚Üí blank back-off arcs (label:Œµ) ‚Äî N‚àí1 of them
  a -> b [label="a:Œµ (back-off)", color="#9E9E9E", style=dashed];
  c -> b [label="b:Œµ (back-off)", color="#9E9E9E", style=dashed];
}

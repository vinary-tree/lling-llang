// ctc-correct.dot — Correct-CTC topology as an all-to-all weighted automaton (N=3:
// blank + 2 labels). `N` states, `N²` arcs: a self-loop on every state plus an arc
// between every ordered pair. Blank (state 0) is both start and final. Laid out with
// `circo` (layout=circo) so the all-to-all symmetry is visible.
//
// SHARED DOT PREAMBLE (palette = docs/diagrams/README.md):
//   bg #FFFFFF · node fill #BBDEFB / border #1565C0 · text #102027 · edge #607D8B
//   best/Viterbi #2E7D32 bold(penwidth=2) · alternative #B0BEC5 · epsilon #9E9E9E dashed
//   final = doublecircle fill #C8E6C9 border #2E7D32 · start = arrow from invisible point
digraph ctc_correct {
  layout=circo;
  bgcolor="#FFFFFF";
  labelloc="t";
  fontname="Helvetica"; fontsize=13;
  label=<<b>Correct-CTC (N=3)</b> — complete graph: N states, N² arcs, self-loops on all states>;
  node  [shape=circle, style=filled, fillcolor="#BBDEFB", color="#1565C0",
         fontcolor="#102027", fontname="Helvetica", penwidth=1.4, width=0.6];
  edge  [color="#607D8B", fontcolor="#37474F", fontname="Helvetica", fontsize=11, penwidth=1.3];

  // start marker into the blank state
  __start__ [shape=point, width=0.01, color="#1565C0"];
  __start__ -> b;

  // blank (state 0) is BOTH start and final → emphasized double ring (orange ASR accent fill)
  b [label="blank\n0", shape=doublecircle, fillcolor="#FFE0B2", color="#E65100"];
  a [label="a\n1"];
  c [label="b\n2"];

  // self-loops (label repetition) — blank emits ε on the output tape
  b -> b [label="ε / -", color="#9E9E9E", style=dashed];
  a -> a [label="a:a"];
  c -> c [label="b:b"];

  // all ordered pairs (the N²−N non-self arcs) — "any label at any time"
  b -> a [label="a:a"];
  a -> b [label="ε / -", color="#9E9E9E", style=dashed];
  b -> c [label="b:b"];
  c -> b [label="ε / -", color="#9E9E9E", style=dashed];
  a -> c [label="b:b"];
  c -> a [label="a:a"];
}

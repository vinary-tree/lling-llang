@startuml differentiable-passes
' Two-pass forward-backward over a WFST: the forward pass accumulates α (log-sum-exp
' over prefixes), the backward pass accumulates β (over suffixes), and arc posteriors
' ∂Z/∂w = exp(α[s] + w + β[t] − Z) fall out of the two. Palette: docs/diagrams/README.md
' (deep-learning tier = purple #E1BEE7 / #6A1B9A).
skinparam backgroundColor #FFFFFF
skinparam shadowing false
skinparam defaultTextAlignment center
skinparam sequence {
  ArrowColor #6A1B9A
  ArrowThickness 1.3
  LifeLineBorderColor #6A1B9A
  LifeLineBackgroundColor #F3E5F5
  ParticipantBorderColor #6A1B9A
  ParticipantBackgroundColor #E1BEE7
  ParticipantFontColor #102027
}

title <b>Forward–backward autograd over a WFST</b>\n<size:11><i>forward score → backward arc-posteriors; <latex>\text{gradient} = -\text{posterior}</latex></i></size>

participant "Neural\nemissions E" as NN #FFE0B2
participant "Forward pass\n<latex>\alpha[s]</latex>" as FWD
participant "Backward pass\n<latex>\beta[s]</latex>" as BWD
participant "Arc gradients\n<latex>\partial Z/\partial w</latex>" as G #C8E6C9

== Forward pass (prefix scores, topological order) ==
NN -> FWD : log-prob arc weights w
note over FWD
  <latex>\alpha[q_0] = \bar{1}</latex> (= 0 in log)
  <latex>\alpha[t] = \alpha[t] \oplus (\alpha[s] \otimes w)</latex>
  for every arc (s, t, w)
end note
FWD -> FWD : <latex>Z = \bigoplus_{f \in F} (\alpha[f] \otimes \rho[f])</latex>

== Backward pass (suffix scores, reverse topological order) ==
FWD -> BWD : partition function Z
note over BWD
  <latex>\beta[f] = \rho[f]</latex> for finals
  <latex>\beta[s] = \beta[s] \oplus (w \otimes \beta[t])</latex>
  for every arc (s, t, w)
end note

== Combine: per-arc posterior ==
FWD -> G : <latex>\alpha[s]</latex>
BWD -> G : <latex>\beta[t]</latex>
note over G
  posterior(arc) =
    <latex>\exp(\alpha[s] + w + \beta[t] - Z)</latex>
  <latex>\partial \text{Loss}/\partial w = -\text{posterior}</latex>
end note
G --> NN : gradients back to emissions

@enduml

// phonetic-rescore.dot — the phonetic-rescoring worked example as a left-to-right
// weighted finite-state acceptor (WFSA). Two acoustically-confused positions
// ("knight"~"night", "mare"~"mayor") are rescored against a reference; because
// "knight" and "night" normalize to the same Zompist form, the interpolated weight
// new_w = (1−λ)·orig + λ·phon_cost boosts the homophone, and the reference words
// "night mayor" become the best (Viterbi) path. Graphviz twin of the lattice ASCII
// art in docs/integration/libgrammstein/phonetic-rescore.md.
//
// SHARED DOT PREAMBLE (palette = docs/diagrams/README.md):
//   bg #FFFFFF · node fill #BBDEFB / border #1565C0 · text #102027 · edge #607D8B
//   best/Viterbi #2E7D32 bold(penwidth=2) · alternative #B0BEC5
//   final = doublecircle fill #C8E6C9 border #2E7D32 · start = arrow from invisible point
digraph phonetic_rescore {
  rankdir=LR;
  bgcolor="#FFFFFF";
  labelloc="t";
  fontname="Helvetica"; fontsize=13;
  label=<<b>Phonetic rescoring (WFSA)</b> — green marks the best path after the reference "night mayor" boosts homophones>;
  node  [shape=circle, style=filled, fillcolor="#BBDEFB", color="#1565C0",
         fontcolor="#102027", fontname="Helvetica", penwidth=1.4, width=0.5];
  edge  [color="#607D8B", fontcolor="#37474F", fontname="Helvetica", fontsize=11, penwidth=1.3];

  // start marker
  __start__ [shape=point, width=0.01, color="#1565C0"];
  __start__ -> n0;

  n0 [label="0"];
  n1 [label="1"];
  n2 [label="2", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];   // final

  // position 0: "knight" vs "night" (acoustic confusion → same phonetic form /nait/)
  // best (Viterbi) path — bold green
  n0 -> n1 [label="night / 0.50",  color="#2E7D32", fontcolor="#1B5E20", penwidth=2.0];
  // homophone boosted from 1.00 → 0.60, but still above the reference word
  n0 -> n1 [label="knight / 0.60", color="#B0BEC5"];

  // position 1: "mare" vs "mayor" (vowel confusion); reference prefers "mayor"
  n1 -> n2 [label="mayor / 0.50", color="#2E7D32", fontcolor="#1B5E20", penwidth=2.0];
  n1 -> n2 [label="mare / 1.00",  color="#B0BEC5"];
}

// token-grouping.dot — token equivalence classes for beam search (LET-Decoder).
// Many tokens share a base-graph state but differ in grammar state; they collapse
// into one TokenGroup keyed by base_state, carrying only the best forward prob
// (⊕ = log-add) for pruning. Word arcs force expansion. Green = the surviving
// group after histogram pruning; grey = pruned.
//
// SHARED DOT PREAMBLE (palette = docs/diagrams/README.md):
//   bg #FFFFFF · token fill #BBDEFB / border #1565C0 · group = HTML green/grey
//   word-arc accent #2E7D32 bold · lazy link #9E9E9E dashed
digraph token_grouping {
  rankdir=LR;
  bgcolor="#FFFFFF";
  labelloc="t";
  fontname="Helvetica"; fontsize=13;
  label=<<b>Token equivalence classes</b> — group by base_state; keep best forward prob (⊕ = log-add) for pruning>;
  node  [shape=circle, style=filled, fillcolor="#BBDEFB", color="#1565C0",
         fontcolor="#102027", fontname="Helvetica", penwidth=1.4, width=0.6];
  edge  [color="#607D8B", fontcolor="#37474F", fontname="Helvetica", fontsize=11, penwidth=1.3];

  // raw tokens: (base_state, grammar_state) pairs entering frame t
  subgraph cluster_tokens {
    label=<tokens at frame t  (base, grammar)>;
    labeljust="l"; color="#455A64"; fontcolor="#37474F"; style=dashed;
    t1 [label="(7, a)"];
    t2 [label="(7, b)"];
    t3 [label="(7, c)"];
    t4 [label="(9, a)"];
  }

  // grouped representation (HTML tables). Group keyed by base_state.
  g7 [shape=plaintext, label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="4"
           color="#2E7D32" bgcolor="#C8E6C9">
      <tr><td><b>TokenGroup base=7</b></td></tr>
      <tr><td>best_forward_prob = ⊕(a, b, c)</td></tr>
      <tr><td>lazy: tokens deferred</td></tr>
    </table>>];
  g9 [shape=plaintext, label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="4"
           color="#607D8B" bgcolor="#B0BEC5">
      <tr><td><b>TokenGroup base=9</b></td></tr>
      <tr><td>best_forward_prob = a</td></tr>
      <tr><td>pruned (outside beam)</td></tr>
    </table>>];

  t1 -> g7 [label="group", color="#2E7D32", penwidth=2.0];
  t2 -> g7 [label="group", color="#2E7D32", penwidth=2.0];
  t3 -> g7 [label="group", color="#2E7D32", penwidth=2.0];
  t4 -> g9 [label="group", color="#B0BEC5"];

  // a word arc forces expansion of the surviving group into materialized tokens
  exp [shape=plaintext, label=<
    <table border="0" cellborder="1" cellspacing="0" cellpadding="4"
           color="#F9A825" bgcolor="#FFF59D">
      <tr><td><b>expand_group(base=7)</b></td></tr>
      <tr><td>materialize tokens at word boundary</td></tr>
    </table>>];
  g7 -> exp [label="word arc → expand", color="#2E7D32", penwidth=2.0];

  // lazy back-trace link (dashed) carried in GroupLink instead of real tokens
  g7 -> g9 [label="GroupLink (lazy back-trace)", color="#9E9E9E", style=dashed,
            arrowhead=vee, constraint=false];
}

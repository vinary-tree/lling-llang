// cascade-lg-composition.dot — label flow through the L ∘ G composition.
// The lexicon L maps phone → word_id; the grammar G maps word_id → word_id; the
// composite L ∘ G maps phone → word_id. Output of L must match input of G on the
// WordId tape for composition to be defined (Mohri, Pereira & Riley 2002).
//
// SHARED DOT PREAMBLE (palette = docs/diagrams/README.md):
//   bg #FFFFFF · node fill #BBDEFB / border #1565C0 · text #102027 · edge #607D8B
//   best/Viterbi #2E7D32 bold(penwidth=2) · alternative #B0BEC5 · epsilon #9E9E9E dashed
//   final = doublecircle fill #C8E6C9 border #2E7D32 · start = arrow from invisible point
digraph cascade_lg_composition {
  rankdir=LR;
  bgcolor="#FFFFFF";
  labelloc="t";
  fontname="Helvetica"; fontsize=13;
  label=<<b>L ∘ G label flow</b> — phone → word_id (L), word_id → word_id (G), phone → word_id (L ∘ G)>;
  node  [shape=circle, style=filled, fillcolor="#BBDEFB", color="#1565C0",
         fontcolor="#102027", fontname="Helvetica", penwidth=1.4, width=0.5];
  edge  [color="#607D8B", fontcolor="#37474F", fontname="Helvetica", fontsize=11, penwidth=1.3];

  // ── Lexicon L: phone (input) → word_id (output) ───────────────────────────
  subgraph cluster_L {
    label=<<b>L</b> — lexicon : phone → word_id>;
    fontcolor="#E65100"; color="#E65100"; style="rounded"; bgcolor="#FFF3E0";
    l0 [label="ℓ₀"];
    l1 [label="ℓ₁"];
    l2 [label="ℓ₂", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];
    l0 -> l1 [label="k : cat"];          // first phone emits the word id
    l1 -> l2 [label="æ : ε", color="#9E9E9E", style=dashed];
    l2 -> l2 [label="t : ε", color="#9E9E9E", style=dashed];
  }

  // ── Grammar G: word_id (input) → word_id (output), identity + LM weight ────
  subgraph cluster_G {
    label=<<b>G</b> — grammar : word_id → word_id>;
    fontcolor="#E65100"; color="#E65100"; style="rounded"; bgcolor="#FFF3E0";
    g0 [label="g₀"];
    g1 [label="g₁", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];
    g0 -> g1 [label="cat : cat / 1.2"];  // identity transducer with LM cost
  }

  // ── Composite L ∘ G: phone (input) → word_id (output) ─────────────────────
  subgraph cluster_LG {
    label=<<b>L ∘ G</b> — composite : phone → word_id>;
    fontcolor="#2E7D32"; color="#2E7D32"; style="rounded"; bgcolor="#E8F5E9";
    m0 [label="m₀"];
    m1 [label="m₁"];
    m2 [label="m₂", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];
    m0 -> m1 [label="k : cat / 1.2", color="#2E7D32", fontcolor="#1B5E20", penwidth=2.0];
    m1 -> m2 [label="æ : ε",  color="#9E9E9E", style=dashed];
    m2 -> m2 [label="t : ε",  color="#9E9E9E", style=dashed];
  }

  // ── Match annotation: L.output (WordId) ≡ G.input (WordId) ─────────────────
  l1 -> g0 [label="match on  word_id 'cat'", style=dotted, color="#1565C0",
            fontcolor="#0D47A1", constraint=false, penwidth=1.2];
}

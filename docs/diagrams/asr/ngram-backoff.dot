// ngram-backoff.dot — n-gram grammar transducer G with Katz back-off arcs.
// Seen n-grams take a direct word arc carrying −log P(wₙ∣h); unseen n-grams take
// the ε back-off arc (cost β(h)) to a shorter-history state and retry at lower
// order. Matches NgramBuilder / BackoffState in src/asr/ngram.rs.
//
// SHARED DOT PREAMBLE (palette = docs/diagrams/README.md):
//   bg #FFFFFF · node fill #BBDEFB / border #1565C0 · text #102027 · edge #607D8B
//   best/Viterbi #2E7D32 bold(penwidth=2) · alternative #B0BEC5 · epsilon #9E9E9E dashed
//   final = doublecircle fill #C8E6C9 border #2E7D32 · start = arrow from invisible point
digraph ngram_backoff {
  rankdir=LR;
  bgcolor="#FFFFFF";
  labelloc="t";
  fontname="Helvetica"; fontsize=13;
  label=<<b>n-gram LM transducer G</b> — solid = seen n-gram arc, dashed grey = ε back-off arc (cost β(h))>;
  node  [shape=circle, style=filled, fillcolor="#BBDEFB", color="#1565C0",
         fontcolor="#102027", fontname="Helvetica", penwidth=1.4, width=0.7];
  edge  [color="#607D8B", fontcolor="#37474F", fontname="Helvetica", fontsize=11, penwidth=1.3];

  __start__ [shape=point, width=0.01, color="#1565C0"];
  __start__ -> bi_the;

  // Bigram history states (order 1) — "the", "cat"
  bi_the [label="⟨the⟩"];
  bi_cat [label="⟨cat⟩"];
  // Unigram back-off state (order 0)
  uni    [label="⟨ε⟩\nunigram", fillcolor="#FFE0B2", color="#E65100"];

  // Seen bigram transitions: word arc with −log P(w | h)
  bi_the -> bi_cat [label="cat : cat / −log P(cat∣the)", color="#2E7D32", fontcolor="#1B5E20", penwidth=2.0];
  bi_cat -> bi_the [label="the : the / −log P(the∣cat)"];

  // Back-off ε-arcs: drop one word of history, pay β(h)
  bi_the -> uni [label="ε : ε / β(the)", color="#9E9E9E", style=dashed];
  bi_cat -> uni [label="ε : ε / β(cat)", color="#9E9E9E", style=dashed];

  // Unigram fall-through arcs: −log P(w) from the back-off state
  uni -> bi_the [label="the : the / −log P(the)", color="#B0BEC5"];
  uni -> bi_cat [label="cat : cat / −log P(cat)", color="#B0BEC5"];
}

// topological-sort.dot — Kahn's algorithm on a diamond DAG. Each node is annotated
// with its in-degree; the algorithm seeds the queue with in-degree-0 nodes and peels
// them off, decrementing successors. The green bold spine shows one valid linear
// order 0,1,2,3 (the diamond admits 0,1,2,3 and 0,2,1,3).
//
// SHARED DOT PREAMBLE (copy into every Graphviz automaton; palette = docs/diagrams/README.md):
//   bg #FFFFFF · node fill #BBDEFB / border #1565C0 · text #102027 · edge #607D8B
//   best/Viterbi #2E7D32 bold(penwidth=2) · alternative #B0BEC5
digraph topological_sort {
  rankdir=LR;
  bgcolor="#FFFFFF";
  labelloc="t";
  fontname="Helvetica"; fontsize=13;
  label=<<b>Topological sort</b> (Kahn) — peel in-degree-0 nodes; annotation = in-degree; green = a valid order>;
  node  [shape=circle, style=filled, fillcolor="#BBDEFB", color="#1565C0",
         fontcolor="#102027", fontname="Helvetica", penwidth=1.4, width=0.7];
  edge  [color="#607D8B", fontcolor="#37474F", fontname="Helvetica", fontsize=11, penwidth=1.3];

  A [label="0\nin=0", fillcolor="#C8E6C9", color="#2E7D32"];   // ready first
  B [label="1\nin=1"];
  C [label="2\nin=1"];
  D [label="3\nin=2", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];
  s0 [shape=point, width=0.01, color="#1565C0"]; s0 -> A;

  // diamond edges; one chosen linearization 0→1→…→3 drawn bold green
  A -> B [label="", color="#2E7D32", penwidth=2.0];
  A -> C [label="", color="#B0BEC5"];
  B -> D [label="", color="#2E7D32", penwidth=2.0];
  C -> D [label="", color="#B0BEC5"];

  // emitted order inset
  order [shape=record, style=filled, fillcolor="#ECEFF1", color="#455A64",
         label="{ emitted order | 0 | 1 | 2 | 3 }"];
}

// synchronization.dot — synchronizing a delayed transducer. LEFT: original arcs put
// input and output out of sync (a:ε then b:x then c:y). RIGHT: synchronized states
// carry the residual delay (q, x|y); a draining tail emits leftover symbols at the
// final state. Grey-dashed = ε on a tape.
//
// SHARED DOT PREAMBLE (copy into every Graphviz automaton; palette = docs/diagrams/README.md):
//   bg #FFFFFF · node fill #BBDEFB / border #1565C0 · text #102027 · edge #607D8B
//   best/Viterbi #2E7D32 bold(penwidth=2) · alternative #B0BEC5 · epsilon #9E9E9E dashed
//   final = doublecircle fill #C8E6C9 border #2E7D32 · transducer accent #B2DFDB/#00695C
digraph synchronization {
  rankdir=LR;
  bgcolor="#FFFFFF";
  labelloc="t";
  fontname="Helvetica"; fontsize=13;
  label=<<b>Synchronization</b> — residual delay tracked in state (q, in∣out); draining tail flushes leftovers at the final state>;
  node  [shape=circle, style=filled, fillcolor="#B2DFDB", color="#00695C",
         fontcolor="#102027", fontname="Helvetica", penwidth=1.4, width=0.5];
  edge  [color="#607D8B", fontcolor="#37474F", fontname="Helvetica", fontsize=11, penwidth=1.3];

  // ── before ────────────────────────────────────────────────────────
  subgraph cluster_before {
    label=<<b>before</b> — a:ε (input ahead), then b:x, c:y; delay swings −1 → 0>;
    color="#00695C"; fontcolor="#004D40"; style="rounded"; bgcolor="#E0F2F1";
    b0 [label="0"];
    b1 [label="1"];
    b2 [label="2"];
    b3 [label="3", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];
    s0 [shape=point, width=0.01, color="#00695C"]; s0 -> b0;
    b0 -> b1 [label="a : ε / 0", color="#9E9E9E", style=dashed, fontcolor="#616161"];
    b1 -> b2 [label="b : x / 0"];
    b2 -> b3 [label="c : y / 0"];
  }

  // ── after ─────────────────────────────────────────────────────────
  subgraph cluster_after {
    label=<<b>after</b> — synchronized: states carry (state, delay); draining emits residuals>;
    color="#2E7D32"; fontcolor="#1B5E20"; style="rounded"; bgcolor="#E8F5E9";
    a0 [label="(0,·)"];
    a1 [label="(1,a∣)"];   // input residual [a]
    a2 [label="(2,·)"];
    a3 [label="(3,·)"];
    aD [label="DRAIN", fillcolor="#FFF59D", color="#F9A825"];
    aF [label="FINAL", shape=doublecircle, fillcolor="#C8E6C9", color="#2E7D32"];
    sa [shape=point, width=0.01, color="#00695C"]; sa -> a0;
    a0 -> a1 [label="a : ε / 0", color="#9E9E9E", style=dashed, fontcolor="#616161"];
    a1 -> a2 [label="b : a / 0", color="#2E7D32", fontcolor="#1B5E20", penwidth=2.0];   // emit residual 'a'
    a2 -> a3 [label="c : x / 0", color="#2E7D32", fontcolor="#1B5E20", penwidth=2.0];
    a3 -> aD [label="ε : y / 0", color="#9E9E9E", style=dashed, fontcolor="#616161"];   // drain leftover 'y'
    aD -> aF [label="ε : ε / 0", color="#9E9E9E", style=dashed, fontcolor="#616161"];
  }
}
